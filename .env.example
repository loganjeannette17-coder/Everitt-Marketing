# ─── Supabase ──────────────────────────────────────────────────────────────────
# Public vars — safe to expose to the browser (used by supabase-js client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER SIDE ONLY. Never expose to the browser.
# Used in Route Handlers / Server Actions to bypass RLS for trusted writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── AI / LLM ──────────────────────────────────────────────────────────────────
# Optional: Claude API for enhanced AI chat (v2 upgrade path)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Optional: lead notification emails. Site functions safely without this.
# RESEND_API_KEY=re_your-resend-api-key
# RESEND_FROM_EMAIL=notifications@yourdomain.com
# RESEND_TO_EMAIL=team@everittmarketing.com

# ─── Analytics ─────────────────────────────────────────────────────────────────
# Optional: PostHog for product analytics (env-driven, safe to omit)
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Optional: Plausible (alternative to PostHog)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=everittmarketing.com

# ─── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://everittmarketing.com
